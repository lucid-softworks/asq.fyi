{
  "lexicon": 1,
  "id": "fyi.asq.question",
  "defs": {
    "main": {
      "type": "record",
      "key": "tid",
      "record": {
        "type": "object",
        "required": ["title", "body", "createdAt"],
        "properties": {
          "title": { "type": "string", "minLength": 10, "maxLength": 300 },
          "body": { "type": "string", "maxLength": 10000 },
          "tags": {
            "type": "array",
            "maxLength": 5,
            "items": { "type": "string", "maxLength": 24 }
          },
          "createdAt": { "type": "string", "format": "datetime" }
        }
      }
    }
  }
}
