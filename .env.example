# Shared
NODE_ENV=development
DATABASE_URL=postgres://postgres:postgres@localhost:5432/asq

# Web + API live in the same TanStack Start service.
# Use 127.0.0.1 (not "localhost") locally so the ATProto OAuth loopback-client
# rules accept our redirect_uri.
PUBLIC_API_URL=http://127.0.0.1:5173
PUBLIC_WEB_URL=http://127.0.0.1:5173

COOKIE_SECRET=change-me-to-a-32-byte-or-longer-secret
OAUTH_PRIVATE_KEY_1=
JETSTREAM_URL=wss://jetstream2.us-east.bsky.network/subscribe
