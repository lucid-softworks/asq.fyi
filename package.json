{
  "name": "asq",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run --filter='@asq/api' --filter='@asq/web' dev",
    "dev:ingester": "bun run --cwd apps/api dev:ingester",
    "build": "bun run --filter='@asq/lexicons' build && bun run --filter='@asq/shared' build && bun run --filter='@asq/web' build",
    "start": "bun run apps/api/src/index.ts",
    "start:api": "bun run apps/api/src/index.ts",
    "start:ingester": "bun run apps/api/src/ingester.ts",
    "start:web": "bun run apps/web/server.ts",
    "typecheck": "bun run --filter='@asq/api' --filter='@asq/web' --filter='@asq/lexicons' --filter='@asq/shared' typecheck"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  }
}
