{
  "name": "asq",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run --filter='@asq/web' dev",
    "dev:ingester": "bun run --cwd apps/ingester dev",
    "build": "bun run --filter='@asq/lexicons' build && bun run --filter='@asq/shared' build && bun run --filter='@asq/web' build",
    "start": "bun run --cwd apps/web start",
    "start:web": "bun run --cwd apps/web start",
    "start:ingester": "bun run --cwd apps/ingester start",
    "db:generate": "bun run --cwd packages/server db:generate",
    "db:migrate": "bun run --cwd packages/server db:migrate",
    "db:studio": "bun run --cwd packages/server db:studio",
    "typecheck": "bun run --filter='@asq/web' --filter='@asq/ingester' --filter='@asq/server' --filter='@asq/lexicons' --filter='@asq/shared' typecheck"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  }
}
